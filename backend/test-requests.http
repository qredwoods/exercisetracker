@host = http://localhost:3000
@NON_EXISTENT_ID = 369b336b8c8867f2cc165159

# ─── AUTH ────────────────────────────────────────────────

### Signup a new user
POST {{host}}/api/auth/signup HTTP/1.1
content-type: application/json

{
    "email": "test@example.com",
    "password": "testpassword123"
}

### Login (captures token for subsequent requests)
# @name login
POST {{host}}/api/auth/login HTTP/1.1
content-type: application/json

{
    "email": "test@example.com",
    "password": "testpassword123"
}

### Login with wrong password
### Expected: 401, {"error": "Invalid email or password."}
POST {{host}}/api/auth/login HTTP/1.1
content-type: application/json

{
    "email": "test@example.com",
    "password": "wrongpassword"
}

### Login with nonexistent email
### Expected: 401, {"error": "Invalid email or password."}
POST {{host}}/api/auth/login HTTP/1.1
content-type: application/json

{
    "email": "nobody@example.com",
    "password": "testpassword123"
}

### Signup with duplicate email
### Expected: 409, {"error": "An account with this email already exists."}
POST {{host}}/api/auth/signup HTTP/1.1
content-type: application/json

{
    "email": "test@example.com",
    "password": "testpassword123"
}

### Signup with short password
### Expected: 400, {"error": "Password must be at least 8 characters."}
POST {{host}}/api/auth/signup HTTP/1.1
content-type: application/json

{
    "email": "short@example.com",
    "password": "abc"
}

# ─── EXERCISES (AUTHENTICATED) ──────────────────────────
# Run the login request above first to capture the token.

### Request without auth token
### Expected: 401, {"error": "Authentication required."}
GET {{host}}/api/exercises HTTP/1.1

### Create exercise: Deadlift
### Expected: 201
# @name deadlift
POST {{host}}/api/exercises HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Deadlift",
    "reps": 12,
    "weight": 30,
    "unit": "kgs",
    "date": "2026-02-18"
}

### Create exercise: Squat
### Expected: 201
POST {{host}}/api/exercises HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Squat",
    "reps": 13,
    "weight": 31,
    "unit": "lbs",
    "date": "2026-02-18"
}

### Create exercise: Deadlift (different date)
### Expected: 201
POST {{host}}/api/exercises HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Deadlift",
    "reps": 14,
    "weight": 32,
    "unit": "kgs",
    "date": "2026-02-24"
}

### Create exercise: Squat (different date)
### Expected: 201
POST {{host}}/api/exercises HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Squat",
    "reps": 15,
    "weight": 33,
    "unit": "lbs",
    "date": "2026-02-24"
}

### Invalid: missing unit
### Expected: 400
POST {{host}}/api/exercises HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Deadlift",
    "reps": 12,
    "weight": 25,
    "date": "2026-02-24"
}

### Invalid: missing date
### Expected: 400
POST {{host}}/api/exercises HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Deadlift",
    "reps": 12,
    "weight": 25,
    "unit": "kgs"
}

### Invalid: weight is 0 with non-bodyweight unit
### Expected: 400
POST {{host}}/api/exercises HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Deadlift",
    "reps": 12,
    "weight": 0,
    "unit": "kgs",
    "date": "2026-02-24"
}

### Invalid: reps is not a number
### Expected: 400
POST {{host}}/api/exercises HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Deadlift",
    "reps": "not a number",
    "weight": 1,
    "unit": "kgs",
    "date": "2026-02-24"
}

### Invalid: bad date format
### Expected: 400
POST {{host}}/api/exercises HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Deadlift",
    "reps": 18,
    "weight": 1,
    "unit": "kgs",
    "date": "2026-aa-24"
}

### Retrieve all exercises for this user
### Expected: 200, array of 4 exercises
GET {{host}}/api/exercises HTTP/1.1
Authorization: Bearer {{login.response.body.accessToken}}

### Retrieve deadlift by ID
### Expected: 200, JSON object with reps 12, weight 30, unit kgs
GET {{host}}/api/exercises/{{deadlift.response.body._id}} HTTP/1.1
Authorization: Bearer {{login.response.body.accessToken}}

### Retrieve non-existent ID
### Expected: 404, {"error": "Not found"}
GET {{host}}/api/exercises/{{NON_EXISTENT_ID}} HTTP/1.1
Authorization: Bearer {{login.response.body.accessToken}}

### Update deadlift: change reps and weight
### Expected: 200, updated JSON object
PUT {{host}}/api/exercises/{{deadlift.response.body._id}} HTTP/1.1
content-type: application/json
Authorization: Bearer {{login.response.body.accessToken}}

{
    "name": "Deadlift",
    "reps": 15,
    "weight": 40,
    "unit": "kgs",
    "date": "2026-02-18"
}

### Delete deadlift by ID
### Expected: 204, no body
DELETE {{host}}/api/exercises/{{deadlift.response.body._id}} HTTP/1.1
Authorization: Bearer {{login.response.body.accessToken}}

### Confirm deletion: retrieve deleted ID
### Expected: 404, {"error": "Not found"}
GET {{host}}/api/exercises/{{deadlift.response.body._id}} HTTP/1.1
Authorization: Bearer {{login.response.body.accessToken}}

### Confirm deletion: view remaining exercises for this user
### Expected: 200, array of 3 exercises
GET {{host}}/api/exercises HTTP/1.1
Authorization: Bearer {{login.response.body.accessToken}}

### Logout
### Expected: 200, {"message": "Logged out."}
POST {{host}}/api/auth/logout HTTP/1.1

### Confirm logout: try to refresh
### Expected: 401, {"error": "No refresh token."}
POST {{host}}/api/auth/refresh HTTP/1.1
